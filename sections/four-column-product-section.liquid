


{% if section.settings.collection != blank %}
<div>
  {% if section.settings.titleBasic != blank %}
  <div class="four-column-product-section-v2"    >
    <div class="container-1300">
    
          
            <h2 class="h2">
              {{ section.settings.titleBasic }}
            </h2>
          
           {% if section.settings.descriptionBasic != blank %}
           <div class="description">
        {{ section.settings.descriptionBasic }}

       </div>
        {% endif %}
     
       
        <ul class="product-list flex-wrap">
           {%- assign collection = collections[section.settings.collection] -%}
            {% for productRelated in collection.products %}
              {% if productRelated != blank %}
                <li class="product-card">
                  {% include 'product_card-collection' with productRelated: productRelated, variant_index: 1, show_price: true, show_tags: true, show_auto_tags: true, show_title: true, show_fav: false, show_secondary_button: false %}
                </li>
              {% endif %}
            {% endfor %}
          </ul>
       
      
    </div>
  </div>
{% endif %}

 {% if section.settings.titleAdvanced != blank %}
  <div class="four-column-product-section-v2"    >
    <div class="container-1300">
    
          
            <h2 class="h2">
              {{ section.settings.titleAdvanced }}
            </h2>
          
           {% if section.settings.descriptionAdvanced != blank %}
           <div class="description">
        {{ section.settings.descriptionAdvanced }}

       </div>
        {% endif %}
     
       
        <ul class="product-list flex-wrap">
           {%- assign collection = collections[section.settings.collection] -%}
            {% for productRelated in collection.products %}
              {% if productRelated != blank %}
                <li class="product-card">
                  {% include 'product_card-collection' with productRelated: productRelated, variant_index: 0, show_price: true, show_tags: true, show_auto_tags: true, show_title: true, show_fav: false, show_secondary_button: false %}
                </li>
              {% endif %}
            {% endfor %}
          </ul>
       
      
    </div>
  </div>
{% endif %}
<div>
  
  {%- assign collection = collections[section.settings.collection] -%}
            {% for productRelated in collection.products %}
    {% render 'product-modal', productData: productRelated %}
  {% endfor %}

    
{%- endif -%}



{% schema %}
{
  "name": "Four Column Product Grid",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "📦 Product grid content"
    },
    {
      "type": "paragraph",
      "content": "Control the heading and description text that appear above this product grid. The section displays products from a single collection in a responsive four-column layout on desktop (automatically adapting to fewer columns on tablet and mobile)."
    },
   
    {
      "type": "text",
      "id": "titleBasic",
      "label": "Basic Section heading",
      "info": "Main title shown above the product grid (for example: 'Featured Products', 'You May Also Like', or 'Complete Your Collection'). Keep it short and clear so customers immediately understand what these products represent."
    },
    {
      "type": "richtext",
      "id": "descriptionBasic",
      "label": "Basic description",
      "info": "Optional rich text that appears under the heading. Use this to explain what is special about this collection, highlight benefits, or provide guidance on how to choose a product."
    },
    {
      "type": "text",
      "id": "titleAdvanced",
      "label": "Advanced Section heading",
      "info": "Main title shown above the product grid (for example: 'Featured Products', 'You May Also Like', or 'Complete Your Collection'). Keep it short and clear so customers immediately understand what these products represent."
    },
    {
      "type": "richtext",
      "id": "descriptionAdvanced",
      "label": "Advanced description",
      "info": "Optional rich text that appears under the heading. Use this to explain what is special about this collection, highlight benefits, or provide guidance on how to choose a product."
    },
     {
          "type": "collection",
          "id": "collection",
          "label": "Product collection source",
          "info": "Select the collection whose products should appear in this grid. Products will be shown following the collection's sort order."
    }
  ],
  "presets": [
    {
      "name": "Four column product grid",
      "category": "Product showcase"
    }
  ]
}
{% endschema %}
