{%- style -%}
  .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtop | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottom | round: 0 }}px !important;
    }

    @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtopmobile | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottomMobile | round: 0 }}px !important;
    }
  }
{%- endstyle -%}


{% if section.settings.collection != blank %}
  <div class="four-column-product-section-v2    section-{{ section.id }}-padding {% if section.settings.hidehrline %}  hide-bottom-hr {% endif %} "  {% if section.settings.sectionID != blank %} id="{{ section.settings.sectionID }}"    {% endif %}>
    <div class="container-1300">
    
          {% if section.settings.title != blank %}
            <h2 class="h2">
              {{ section.settings.title }}
            </h2>
          {% endif %}
           {% if section.settings.description != blank %}
           <div class="description">
        {{ section.settings.description }}

       </div>
        {% endif %}
     
       
          <ul class="product-list flex-wrap">
           {%- assign collection = collections[section.settings.collection] -%}
            {% for productRelated in collection.products %}
             

              {% if productRelated != blank %}
                <li class="product-card">
                  {% include 'product_card'  with  productRelated: productRelated , show_price: true, show_tags: true, show_auto_tags: true, show_title: true, show_fav: false, show_secondary_button: false %}
          </li>
              {% endif %}
            {% endfor %}
          </ul>
       
      
    </div>
  </div>

  {% if section.blocks.size > 0 %}
  {%- assign collection = collections[section.settings.collection] -%}
            {% for productRelated in collection.products %}
    {% render 'product-modal', productData: productRelated %}
  {% endfor %}
{% endif %}

    
{%- endif -%}



{% schema %}
{
  "name": "Four Column Product Grid",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "📦 Product grid content"
    },
    {
      "type": "paragraph",
      "content": "Control the heading and description text that appear above this product grid. The section displays products from a single collection in a responsive four-column layout on desktop (automatically adapting to fewer columns on tablet and mobile)."
    },
   
    {
      "type": "text",
      "id": "title",
      "label": "Section heading",
      "info": "Main title shown above the product grid (for example: 'Featured Products', 'You May Also Like', or 'Complete Your Collection'). Keep it short and clear so customers immediately understand what these products represent."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Introductory description",
      "info": "Optional rich text that appears under the heading. Use this to explain what is special about this collection, highlight benefits, or provide guidance on how to choose a product."
    },
     {
          "type": "collection",
          "id": "collection",
          "label": "Product collection source",
          "info": "Select the collection whose products should appear in this grid. Products will be shown following the collection's sort order."
    },
    {
      "type": "header",
      "content": "📏 Section spacing & layout"
    },
    {
      "type": "paragraph",
      "content": "Fine-tune the vertical spacing above and below this section for desktop and mobile. Adjust these values to create comfortable breathing room between this grid and neighboring sections."
    },
    {
      "type": "range",
      "id": "paddingtop",
      "min": 0,
      "max": 140,
      "step": 2,
      "unit": "px",
      "label": "Top spacing (desktop)",
      "info": "Controls the space above this section on desktop screens. Increase to push the grid further down from the content above; decrease for a more compact layout.",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingtopmobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top spacing (mobile)",
      "info": "Controls the space above this section on mobile screens. Mobile spacing is usually tighter so important content remains visible without excessive scrolling.",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingbottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom spacing (desktop)",
      "info": "Controls the space below this section on desktop screens. Use this to clearly separate the grid from the next section that follows.",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingbottomMobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom spacing (mobile)",
      "info": "Controls the space below this section on mobile screens. Adjust to avoid the grid feeling either cramped or too far from the next section.",
      "default": 0
    },
    {
      "type": "header",
      "content": "🛠 Dev settings (for theme developers)"
    },
    {
          "type": "checkbox",
          "id": "hidehrline",
          "label": "Hide bottom divider line",
          "info": "When enabled, hides the horizontal divider line that normally appears beneath this section. Useful when stacking multiple product sections together without visual breaks.",
          "default": false
    }
  ],
  "presets": [
    {
      "name": "Four column product grid",
      "category": "Product showcase"
    }
  ]
}
{% endschema %}
