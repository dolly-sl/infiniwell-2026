{%- style -%}
{%  comment %}
  .section-{{ section.id }}-padding-top{
      padding-top: {{ section.settings.paddingtop | round: 0 }}px;
    }
    .section-{{ section.id }}-padding-bottom{
      padding-bottom: {{ section.settings.paddingbottom | round: 0 }}px;
    }
    @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding-top{
      padding-top: {{ section.settings.paddingtopmobile | round: 0 }}px;

    }
    .section-{{ section.id }}-padding-bottom{
      padding-bottom: {{ section.settings.paddingbottommobile | round: 0 }}px;
    }
  }
    {%  endcomment %}
{%- endstyle -%}

{% if section.settings.description != blank and section.settings.title != blank %}
  <div
    class="full-width-content-box"
    data-aos="fade-up"
    data-aos-duration="2000"
  >
    <div class="container-1300">
      <div class="box">
      <div class="content ">
        {% if section.settings.title != blank %}
          <h2>
            {{ section.settings.title }}
           
          </h2>
        {% endif %}
        {% if section.settings.subtitle != blank %}
          <p class="subtitle">
            {{ section.settings.subtitle }}
           
          </p>
         {% endif %}
<div class="full-format">
        {{ section.settings.description }}

       </div>
      </div>
      </div>
    </div>
  </div>
{% endif %}
{% schema %}
{
  "name": "Full width content box",
  "settings": [
    {
      "type": "header",
      "content": "📝 Content settings"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Main heading",
      "info": "Primary title displayed at the top of the content box. Use a clear, concise phrase that describes the message of this section."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Supporting subtitle",
      "info": "Optional line of text that appears below the main heading. Use this to add a short clarification, highlight a key benefit, or set context."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Body content",
      "info": "Rich text content shown beneath the heading and subtitle. You can include formatted text, links, and lists to explain details, tell a story, or provide instructions."
    }
    
  ],

  "presets": [
    {
      "name": "Full width content box"
    }
  ]
}
{% endschema %}
