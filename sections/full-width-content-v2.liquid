{%- style -%}
{%  comment %}
  .section-{{ section.id }}-padding-top{
      padding-top: {{ section.settings.paddingtop | round: 0 }}px;
    }
    .section-{{ section.id }}-padding-bottom{
      padding-bottom: {{ section.settings.paddingbottom | round: 0 }}px;
    }
    @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding-top{
      padding-top: {{ section.settings.paddingtopmobile | round: 0 }}px;

    }
    .section-{{ section.id }}-padding-bottom{
      padding-bottom: {{ section.settings.paddingbottommobile | round: 0 }}px;
    }
  }
    {%  endcomment %}
{%- endstyle -%}

{% if section.settings.description != blank and section.settings.title1 != blank %}
  <div
    class="full-width-content v2 section-{{ section.id }}-padding-top section-{{ section.id }}-padding-bottom"
    data-aos="fade-up"
    data-aos-duration="2000"
  >
    <div class="container-1320">
      <div class="content full-format">
        {% if section.settings.title1 != blank %}
          <h1>
            {{ section.settings.title1 }}
            {% if section.settings.title2 != blank %}
              <span class="color-grey h1">{{ section.settings.title2 }}</span>
            {% endif %}
          </h1>
        {% endif %}

        {{ section.settings.description }}

        {% if section.settings.buttonText != blank %}
          <a
            href="{{ section.settings.buttonLink }}"
            title="Read More About {{ section.settings.buttonText }}"
            aria-label="Read More About {{ section.settings.buttonText }}"
            class="btn--primary m-t-15"
          >
            {{- section.settings.buttonText -}}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
{% endif %}
{% schema %}
{
  "name": "Full width content v2",
  "settings": [
    {
      "type": "header",
      "content": "📝 Content settings"
    },
    {
      "type": "text",
      "id": "title1",
      "label": "Main heading (black)",
      "info": "Primary part of the heading, displayed in black. Use a short, clear phrase that introduces the key message of this section."
    },
    {
      "type": "text",
      "id": "title2",
      "label": "Accent heading (grey)",
      "info": "Optional second part of the heading, displayed in grey next to the main heading. Ideal for highlighting a keyword or complementary phrase."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Body content",
      "info": "Rich text content shown underneath the heading. Use this area for detailed copy, storytelling, or explanations. You can include formatting, links, and lists."
    },
    {
      "type": "text",
      "id": "buttonText",
      "label": "Button text",
      "info": "Text displayed inside the call-to-action button (for example: 'Learn more', 'Shop now', or 'Read story'). Leave blank to hide the button."
    },
    {
      "type": "url",
      "id": "buttonLink",
      "label": "Button link",
      "info": "Destination URL for the call-to-action button. Paste a full link or select a page so customers know where they will be taken when they click."
    },
    {
      "type": "header",
      "content": "📏 Section spacing (advanced)",
      "info": "Controls the vertical spacing above and below this section. These options are primarily intended for theme developers or advanced users fine-tuning layout."
    },
    {
      "type": "range",
      "id": "paddingtop",
      "min": 0,
      "max": 140,
      "step": 2,
      "unit": "px",
      "label": "Top spacing (desktop)",
      "info": "Space above this section on desktop screens. Increase to push the block further down from the content above; decrease for a more compact layout.",
      "default": 90
    },
    {
      "type": "range",
      "id": "paddingtopmobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top spacing (mobile)",
      "info": "Space above this section on mobile screens. Mobile spacing is usually tighter so important content remains visible without excessive scrolling.",
      "default": 80
    },
    {
      "type": "range",
      "id": "paddingbottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom spacing (desktop)",
      "info": "Space below this section on desktop screens. Use this to clearly separate it from the next section that follows.",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingbottommobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom spacing (mobile)",
      "info": "Space below this section on mobile screens. Adjust to avoid the content feeling either cramped or too far from the next section.",
      "default": 0
    }
  ],

  "presets": [
    {
      "name": "Full width content v2"
    }
  ]
}
{% endschema %}
